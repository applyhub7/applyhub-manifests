apiVersion: v1
kind: Service
metadata:
  name: application-service-minio-svc
  namespace: databases
  labels:
    app: application-service-minio
    tier: database
spec:
  type: ClusterIP
  ports:
    - name: api
      port: 9000
      targetPort: 9000
    - name: console
      port: 9001
      targetPort: 9001
  selector:
    app: application-service-minio
